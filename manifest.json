{
  "manifest_version": 3,
  "name": "Any AI Bridge",
  "version": "1.0.0",
  "description": "本地混合专家大模型聚合助手",
  "permissions": ["sidePanel", "tabs", "scripting"],
  "host_permissions": ["https://chat.deepseek.com/*"],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "打开 Any AI Bridge"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["src/content/deepseek.js"]
    }
  ]
}