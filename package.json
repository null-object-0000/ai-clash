{
    "name": "ai-clash",
    "description": "💥 你的赛博董事会。一次提问，多款满血 AI 同屏对撞。零成本利用网页原生算力进行交叉验证，自带 AI 裁判一键归纳最优解，专治模型偏科与幻觉。",
    "license": "GPL-3.0-or-later",
    "private": true,
    "version": "1.1.0",
    "type": "module",
    "workspaces": [
        "packages/inject"
    ],
    "scripts": {
        "dev": "bun run build:inject && tsc --noEmit && vite build --watch",
        "dev:docs": "cd docs && bun dev",
        "typecheck": "tsc --noEmit && (cd packages/inject && bun run typecheck)",
        "build:inject": "bun --filter @ai-clash/inject build",
        "build": "bun run build:inject && tsc --noEmit && vite build",
        "build:test": "bun run build:inject && tsc --noEmit && vite build && bun run test",
        "test": "playwright test",
        "test:ui": "playwright test --ui"
    },
    "dependencies": {
        "@ant-design/icons": "^6.1.1",
        "@ant-design/x": "^2.5.0",
        "@ant-design/x-markdown": "^2.5.0",
        "@ant-design/x-sdk": "^2.5.0",
        "@lobehub/icons": "^5.4.0",
        "antd": "^6.3.5",
        "antd-style": "^4.1.0",
        "dayjs": "^1.11.20",
        "motion": "^12.38.0",
        "openai": "^6.34.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-markdown": "^10.1.0",
        "zustand": "^5.0.12"
    },
    "sideEffects": false,
    "devDependencies": {
        "@crxjs/vite-plugin": "^2.4.0",
        "@playwright/test": "^1.59.1",
        "@types/chrome": "^0.1.40",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react-swc": "^4.3.0",
        "cross-env": "^10.1.0",
        "typescript": "~5.9.3",
        "vite": "^7.3.2",
        "vite-plugin-compression": "^0.5.1",
        "vite-plugin-zip-pack": "^1.2.4"
    }
}